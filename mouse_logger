import sys
from PyQt6.QtWidgets import QApplication, QWidget
from PyQt6.QtCore import Qt

class MouseLogger(QWidget):
    def __init__(self):
        super().__init__()

        self.setWindowTitle("Touch Logger")
        
        self.setWindowFlags(
            Qt.WindowType.FramelessWindowHint
        )

        self.setAttribute(
            Qt.WidgetAttribute.WA_AcceptTouchEvents,
            True
        )

        self.showFullScreen()

        print("Touch the screen...")

    def mousePressEvent(self, event):
        print(
            f"DOWN X={event.position().x():.1f} "
            f" Y={event.position().y():.1f}"
        )
    def mouseMovesEvent(self, event):
        print(
            f"MOVE X={event.position().x():.1f} "
            f" Y={event.position().y():.1f}"
        )
    def mouseReleaseEvent(self, event):
        print(
            f"UP X={event.position().x():.1f} "
            f" Y={event.position().y():.1f}"
        )

app = QApplication(sys.argv)

window = MouseLogger()
window.show()

sys.exit(app.exec())
